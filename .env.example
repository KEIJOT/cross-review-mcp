# Cross-Review MCP - API Keys (v0.4.0, 2026-02-22)
# Set the keys for whichever models you want to use.

# Default reviewers (used if CROSS_REVIEW_MODELS is not set)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key

# Additional providers
DEEPSEEK_API_KEY=sk-your-deepseek-key
MISTRAL_API_KEY=your-mistral-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Choose your reviewers (optional — defaults to GPT-5.2 + Gemini 3 Flash)
#
# Available shorthands:
#   gpt-5.2          GPT-5.2 ($1.75/M in)         needs OPENAI_API_KEY
#   gpt-5.2-instant  GPT-5.2 Instant ($0.80/M in) needs OPENAI_API_KEY
#   gpt-4o           GPT-4o legacy ($2.50/M in)    needs OPENAI_API_KEY
#   gemini-3.1-pro   Gemini 3.1 Pro ($1.25/M in)   needs GEMINI_API_KEY
#   gemini-3-pro     Gemini 3 Pro ($1.25/M in)      needs GEMINI_API_KEY
#   gemini-flash     Gemini 3 Flash ($0.10/M in)    needs GEMINI_API_KEY
#   gemini-2.5-flash Gemini 2.5 Flash ($0.15/M in)  needs GEMINI_API_KEY
#   deepseek         DeepSeek V3 ($0.14/M in)       needs DEEPSEEK_API_KEY
#   deepseek-r1      DeepSeek R1 ($0.55/M in)       needs DEEPSEEK_API_KEY
#   mistral          Mistral Large ($2.00/M in)      needs MISTRAL_API_KEY
#   qwen             Qwen3 32B (free via OpenRouter)  needs OPENROUTER_API_KEY
#   llama            Llama 3.3 70B (free via OpenRouter) needs OPENROUTER_API_KEY
#
# Examples:
# CROSS_REVIEW_MODELS=["gpt-5.2","gemini-flash","deepseek"]
# CROSS_REVIEW_MODELS=["deepseek","gemini-flash"]
# CROSS_REVIEW_MODELS=["llama","qwen"]
