{
  "name": "cross-review-mcp",
  "version": "0.5.2",
  "description": "Cross-LLM consensus for development blockers - Get guidance from 5 AI models simultaneously",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cross-review-mcp": "./dist/index.js",
    "cross-review": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "ROADMAP_v1.0.0.md",
    ".env.example",
    "claude.config.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "npm run build && node test/smoke.test.js",
    "test:integration": "npm run build && node test/integration.test.js",
    "test:all": "npm run build && node test/smoke.test.js && node test/integration.test.js",
    "test:e2e": "npm run build && node test/e2e.test.mjs",
    "prepublishOnly": "npm run build",
    "inspect": "pkill -9 node; sleep 3; npx @modelcontextprotocol/inspector node dist/index.js",
    "serve": "node dist/index.js --mode http --port 6280",
    "serve:both": "node dist/index.js --mode both --port 6280"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "llm",
    "consensus",
    "peer-review",
    "cross-validation",
    "developer-guidance",
    "debugging",
    "claude",
    "gpt",
    "gemini",
    "ai"
  ],
  "author": "Keijo Tuominen <keijo@boxsight.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KEIJOT/cross-review-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/KEIJOT/cross-review-mcp/issues"
  },
  "homepage": "https://github.com/KEIJOT/cross-review-mcp#readme",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "express": "^5.1.0",
    "openai": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.11.24",
    "dotenv": "^17.3.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
